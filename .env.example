# Ensemble configuration
# Copy to .env and adjust values for your environment.

# === Agent API keys (required for the corresponding agent) ===
# Set the keys for whichever agents you plan to use. Missing keys
# only affect that agent — others continue to work.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Server
ENSEMBLE_PORT=23000
# ENSEMBLE_CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# URLs
# ENSEMBLE_URL=http://localhost:23000

# Data and agent config
# ENSEMBLE_DATA_DIR=~/.ensemble
# ENSEMBLE_AGENTS_CONFIG=./agents.json
# ENSEMBLE_AGENT_FLAGS=

# Watchdog
# ENSEMBLE_WATCHDOG_NUDGE_MS=90000
# ENSEMBLE_WATCHDOG_STALL_MS=180000

# Telegram notifications (optional)
# ENSEMBLE_TELEGRAM_BOT_TOKEN=
# ENSEMBLE_TELEGRAM_CHAT_ID=

# Metadata
# ENSEMBLE_PROJECT=
# ENSEMBLE_CREATED_BY=
